# ── AI Service Configuration ───────────────────────────────────────────────────
# Copy this file to .env and fill in values.

# Server
HOST=0.0.0.0
PORT=8001

# Model artifacts directory (mounted as a Docker volume)
MODEL_PATH=/app/models

# Model version tag (must match artifact filenames: champion_lr_model.{VERSION}.pkl)
MODEL_VERSION=v4.1_20260503

# Logging
LOG_LEVEL=INFO

# ── Derived (no need to change) ────────────────────────────────────────────────
# FEATURE_COLUMNS = 10 raw GMSC features (defined in app/core/config.py)
# RISK_PROB_THRESHOLD = 0.5 (default threshold)
# SCORE_MIN = 300, SCORE_MAX = 850
